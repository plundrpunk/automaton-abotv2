# Docker and Compose defaults for abot-v3 hands.

# AMS base URL as seen from inside the container.
# macOS Docker Desktop supports host.docker.internal directly.
# The compose file also adds a host-gateway mapping for Linux compatibility.
AUTOMATON_AMS_URL=http://host.docker.internal:3001

# Optional AMS API key if your AMS requires authentication.
AUTOMATON_AMS_API_KEY=

# Body identity is set per service in docker-compose.hands.yml.
# For single-container runs, set both values to the same body name.
# Example:
# AUTOMATON_AGENT_NAME=researcher
# AUTOMATON_AGENT_ID=researcher

# Optional runtime verbosity override.
# Example: trace, debug, info, warn, error
# RUST_LOG=info
