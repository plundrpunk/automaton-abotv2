# AutomatanAbot v2 Configuration
# Copy to .env and fill in your values

# --- Agent Identity ---
ASSISTANT_NAME=Abot

# --- AMS Connection (required) ---
# Your AMS instance URL
AMS_URL=https://your-ams-instance.com
# Agent credentials (get these from AMS dashboard)
AMS_AGENT_ID=
AMS_TENANT_ID=
AMS_AGENT_TOKEN=
# MCP endpoint for agent tools
AMS_MCP_ENDPOINT=https://your-ams-instance.com:3002/sse
# Communications gateway URL (for multi-channel messaging)
AMS_GATEWAY_URL=https://your-ams-instance.com:18800

# --- Optional: Claude API Key ---
# If not using OAuth, provide an API key
# ANTHROPIC_API_KEY=sk-ant-...

# --- Container Settings ---
CONTAINER_IMAGE=automatan-agent:latest
MAX_CONCURRENT_CONTAINERS=5
IDLE_TIMEOUT=1800000
CONTAINER_TIMEOUT=1800000

# --- Misc ---
LOG_LEVEL=info
TZ=America/New_York
HEALTH_PORT=8080
